# 应用配置
APP_NAME=SuperBizAgent
DEBUG=True
HOST=0.0.0.0
PORT=9900

# DashScope 配置（必填）
DASHSCOPE_API_KEY=你的DashScope API Key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# 两阶段 RAG 检索配置
RAG_MODEL=qwen-max
RAG_COARSE_K=15
RAG_FINE_K=4
RERANK_MODEL=qwen3-vl-rerank

# 文档分块配置
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# 腾讯云 CLS 配置（可选 — 填入以启用真实日志查询）
TENCENTCLOUD_SECRET_ID=你的SecretId
TENCENTCLOUD_SECRET_KEY=你的SecretKey
TENCENTCLOUD_REGION=ap-guangzhou

# MCP 服务配置
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# Prometheus（告警查询工具等）
PROMETHEUS_BASE_URL=http://127.0.0.1:9090
PROMETHEUS_REQUEST_TIMEOUT=10.0
